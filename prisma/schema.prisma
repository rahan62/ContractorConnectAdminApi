generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  CONTRACTOR
  SUBCONTRACTOR
  TEAM
  ADMIN
  OPERATOR
}

enum ContractStatus {
  DRAFT
  OPEN_FOR_BIDS
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ReferenceStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PenaltyType {
  AVAILABILITY_ABUSE
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String

  userType UserType?

  emailVerified DateTime?

  username  String? @unique
  bio       String?
  logoUrl   String?
  bannerUrl String?
  location  String?

  companyName           String?
  companyTaxOffice      String?
  companyTaxNumber      String? @unique
  authorizedPersonName  String?
  authorizedPersonPhone String?

  signatureAuthDocUrl        String?
  taxCertificateDocUrl       String?
  tradeRegistryGazetteDocUrl String?

  tokenBalance      Int @default(0)
  freeContractsUsed Int @default(0)

  // Trust & penalties
  penaltyPoints Int        @default(0)
  penalties     Penalty[]

  isVerified Boolean @default(false)

  contractsCreated  Contract[]               @relation("UserContractsCreated")
  contractsAsClient Contract[]               @relation("UserContractsAsClient")
  bids              Bid[]
  messagesSent      Message[]                @relation("MessagesSent")
  messagesReceived  Message[]                @relation("MessagesReceived")
  complaints        Complaint[]
  payments          Payment[]
  ads               Ad[]
  contactRequests   ContactRequest[]
  emailTokens       EmailVerificationToken[]
  comments          Comment[]
  teamsLed          Team[]
  teamMemberships   TeamMember[]
  referencesOwned   CompanyReference[]         @relation("ReferenceOwner")
  referencesToCheck CompanyReference[]         @relation("ReferenceVerifier")
  capabilities      UserCapability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Penalty {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  points    Int
  type      PenaltyType?
  reason    String?
  createdAt DateTime    @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  leaderId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leader      User                 @relation(fields: [leaderId], references: [id])
  members     TeamMember[]
  availabilityPosts TeamAvailabilityPost[]
}

model TeamAvailabilityPost {
  id          String   @id @default(cuid())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  title       String
  description String?
  // Profession / capability that best represents this team for this availability window
  profession   CapabilityCategory @relation(fields: [professionId], references: [id], onDelete: Cascade)
  professionId String
  availableFrom DateTime
  availableTo   DateTime
  totalDays     Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  fullName  String
  email     String?
  phone     String?
  role      String?
  createdAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model Contract {
  id          String         @id @default(cuid())
  title       String
  description String?
  status      ContractStatus @default(DRAFT)

  // Urgent / team-focused jobs
  isUrgent Boolean @default(false)

  contractor   User?  @relation("UserContractsCreated", fields: [contractorId], references: [id])
  contractorId String?

  client   User?  @relation("UserContractsAsClient", fields: [clientId], references: [id])
  clientId String?

  budget   Int?
  currency String?
  startsAt DateTime?
  totalDays Int?
  endsAt   DateTime?

  dwgFiles String?
  imageUrls String?

  bids       Bid[]
  comments   Comment[]
  messages   Message[]
  complaints Complaint[]
  payments   Payment[]
  capabilities ContractCapability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonetizationConfig {
  id                       Int @id @default(1)
  monthlySubscriptionPrice Int
  yearlySubscriptionPrice  Int
  featuredListingPrice     Int
  tokenUnitPrice           Int
  vatRate                  Int
  tokensPerContract        Int
  tokensPerBid             Int
  tokensPerAvailabilityPost Int
  tokensPerUrgentJob       Int
}

model Bid {
  id       String    @id @default(cuid())
  amount   Int
  currency String?
  documentUrl String?
  status   BidStatus @default(PENDING)

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  bidder   User   @relation(fields: [bidderId], references: [id])
  bidderId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyReference {
  id          String          @id @default(cuid())
  title       String
  description String?
  location    String?
  evidenceUrl String?
  status      ReferenceStatus @default(PENDING)
  verifierNote String?
  startsAt    DateTime?
  completedAt DateTime?

  owner   User   @relation("ReferenceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  verifier   User?   @relation("ReferenceVerifier", fields: [verifierId], references: [id])
  verifierId String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  verifiedAt DateTime?
  rejectedAt DateTime?
}

model CapabilityCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)

  parent   CapabilityCategory?  @relation("CapabilityTree", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children CapabilityCategory[] @relation("CapabilityTree")

  users            UserCapability[]
  contracts        ContractCapability[]
  teamAvailability TeamAvailabilityPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCapability {
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  capability   CapabilityCategory @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  capabilityId String
  createdAt    DateTime           @default(now())

  @@id([userId, capabilityId])
}

model ContractCapability {
  contract     Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId   String
  capability   CapabilityCategory  @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  capabilityId String
  createdAt    DateTime            @default(now())

  @@id([contractId, capabilityId])
}

model Comment {
  id      String @id @default(cuid())
  content String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  author   User?  @relation(fields: [authorId], references: [id])
  authorId String?

  createdAt DateTime @default(now())
}

model Complaint {
  id          String          @id @default(cuid())
  title       String
  description String?
  status      ComplaintStatus @default(OPEN)

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  user   User?  @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id      String @id @default(cuid())
  content String

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  sender   User   @relation("MessagesSent", fields: [senderId], references: [id])
  senderId String

  recipient   User   @relation("MessagesReceived", fields: [recipientId], references: [id])
  recipientId String

  createdAt DateTime @default(now())
}

model Payment {
  id       String        @id @default(cuid())
  amount   Int
  currency String?
  status   PaymentStatus @default(PENDING)

  user   User?  @relation(fields: [userId], references: [id])
  userId String?

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactRequest {
  id      String @id @default(cuid())
  name    String
  email   String
  message String

  user   User?  @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())
}

model Ad {
  id       String  @id @default(cuid())
  title    String
  content  String?
  imageUrl String?
  linkUrl  String?
  isActive Boolean @default(true)

  owner   User?  @relation(fields: [ownerId], references: [id])
  ownerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailVerificationToken {
  id      String   @id @default(cuid())
  token   String   @unique
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  expires DateTime

  createdAt DateTime @default(now())
}

model Operator {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  isActive     Boolean  @default(true)

  roles OperatorRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  operators   OperatorRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OperatorRole {
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  operatorId String

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  assignedAt DateTime @default(now())

  @@id([operatorId, roleId])
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       String

  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String

  assignedAt DateTime @default(now())

  @@id([roleId, permissionId])
}

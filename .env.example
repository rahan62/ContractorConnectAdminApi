# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Server (many hosts set PORT=8080 — that is fine)
PORT="4000"

# Comma-separated browser origins allowed to call this API (admin UI). Example:
# ADMIN_CORS_ORIGINS="https://admin.yuklenicim.com,http://localhost:3001"

# Admin auth
ADMIN_JWT_SECRET="replace-with-a-long-random-secret"

# Cloudflare Turnstile
ADMIN_TURNSTILE_ENABLED="false"
TURNSTILE_SECRET_KEY=""

# Initial super admin seed
ADMIN_SUPER_EMAIL="admin@taseron.local"
ADMIN_SUPER_PASSWORD="ChangeMe123!"

# Optional monetization defaults
ADMIN_MONTHLY_SUBSCRIPTION_PRICE="1999"
ADMIN_YEARLY_SUBSCRIPTION_PRICE="19999"
ADMIN_FEATURED_LISTING_PRICE="499"
ADMIN_TOKEN_UNIT_PRICE="10"
ADMIN_VAT_RATE="20"
